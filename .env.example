# =============================================================================
#  Shopify Admin API credentials for the /api/upload EPS upload endpoint
# =============================================================================
#
#  HOW TO USE THIS FILE
#  --------------------
#  1. Copy it to `.env`  ->  `cp .env.example .env`   (the .env is gitignored)
#  2. Fill in the values below by following each guide.
#  3. Set the SAME three variables in the Vercel project:
#       Vercel -> your project -> Settings -> Environment Variables
#       (add each for the "Production" environment, then redeploy)
#
#  These are read in app/routes/api.upload.jsx. If SHOPIFY_SHOP /
#  SHOPIFY_CLIENT_ID / SHOPIFY_CLIENT_SECRET are missing, the endpoint returns
#  HTTP 500 with a "Server missing ... env vars" message instead of uploading.
#
#  NEVER commit real secrets. If the token ever leaks, rotate it (see below).
#
#  ⚠️ SERVER-BOOT VARS (required or the WHOLE function crashes on Vercel):
#     The embedded Shopify admin app boots before any route runs. If these are
#     unset, shopifyApp()/PrismaClient throw at startup and even /api/upload
#     returns a 500 "FUNCTION_INVOCATION_FAILED". Set BOTH in Vercel:
#       SHOPIFY_APP_URL  — see section at the bottom of this file
#       DATABASE_URL     — see section at the bottom of this file
# =============================================================================


# -----------------------------------------------------------------------------
#  SHOPIFY_SHOP  —  your store's permanent .myshopify.com domain
# -----------------------------------------------------------------------------
#  This is the internal store domain, NOT your custom/public domain.
#
#  Where to find it:
#    Shopify admin -> Settings -> Domains
#    Look for the domain ending in ".myshopify.com" (e.g. logo-mat-central.myshopify.com)
#    OR read it from the admin URL in your browser:
#      https://admin.shopify.com/store/<THIS-PART>  -> add ".myshopify.com"
#
#  Format: your-store.myshopify.com   (no https://, no trailing slash)
# -----------------------------------------------------------------------------
SHOPIFY_SHOP=logo-mat-central.myshopify.com


# -----------------------------------------------------------------------------
#  SHOPIFY_CLIENT_ID + SHOPIFY_CLIENT_SECRET  —  Dev Dashboard app credentials
# -----------------------------------------------------------------------------
#  Shopify disabled creating new legacy custom apps (which gave static shpat_
#  tokens) on 2026-01-01. Instead, the /api/upload route uses the CLIENT
#  CREDENTIALS GRANT: it POSTs these to https://<shop>/admin/oauth/access_token
#  and gets a short-lived (~24h) shpat_ token per request. No static token to
#  store, no OAuth redirect, no DB.
#
#  One-time setup:
#    1. Dev Dashboard (dev.shopify.com/dashboard) -> Apps -> your app.
#    2. Versions -> Access -> Scopes: include write_files (it implies read_files).
#       Release a version if you changed scopes.
#    3. App overview -> Installs -> "Install app" -> select this store.
#       (A DNS/redirect error page after approving is harmless — Shopify records
#        the install before redirecting. The App URL can point anywhere valid.)
#    4. Settings -> Credentials: copy Client ID and Client secret below.
#
#  Requirements (else the token call errors):
#    - App must be developed by the same org that owns the store (it is).
#    - App must be INSTALLED on the store (error: "app_not_installed" if not).
#
#  To ROTATE (if leaked): Dev Dashboard -> Settings -> Secret -> Rotate, then
#  update SHOPIFY_CLIENT_SECRET here and in Vercel.
#
#  Client ID format:     32-char hex
#  Client secret format: shpss_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# -----------------------------------------------------------------------------
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=


# -----------------------------------------------------------------------------
#  SHOPIFY_API_VERSION  —  Admin API version (optional)
# -----------------------------------------------------------------------------
#  Leave as-is unless you have a reason to change it. If unset, the code
#  defaults to "2025-07". Valid versions are listed at:
#    Shopify admin app -> API credentials, or
#    https://shopify.dev/docs/api/admin (release notes)
#  Use a stable version in "YYYY-MM" format.
# -----------------------------------------------------------------------------
SHOPIFY_API_VERSION=2025-07


# -----------------------------------------------------------------------------
#  SHOPIFY_APP_URL  —  the app's own deployed URL (SERVER-BOOT, required)
# -----------------------------------------------------------------------------
#  The embedded Shopify admin app (app/shopify.server.js) calls shopifyApp()
#  at startup. An empty appUrl makes it THROW ("Detected an empty appUrl
#  configuration"), which crashes the entire serverless function — so even the
#  standalone /api/upload route returns 500. Setting this fixes the boot crash.
#
#  Value: the public URL of THIS deployment, e.g. your Vercel domain:
#    https://custom-email-pearl.vercel.app   (no trailing slash)
#  Update it if the Vercel domain changes.
# -----------------------------------------------------------------------------
SHOPIFY_APP_URL=


# -----------------------------------------------------------------------------
#  DATABASE_URL  —  Supabase Postgres connection string (SERVER-BOOT, required)
# -----------------------------------------------------------------------------
#  ONE Supabase database holds everything:
#    - Shopify sessions  -> Prisma (prisma/schema.prisma `Session` model);
#                           app/db.server.js runs `new PrismaClient()` at boot,
#                           so an unset/invalid url crashes the whole function.
#    - form_submissions  -> app/lib/supabase.server.js (postgres.js).
#
#  Use the Supabase "Transaction pooler" string (recommended for serverless):
#    Supabase -> Project Settings -> Database -> Connection string -> Transaction.
#    host: ...pooler.supabase.com   port: 6543   (?pgbouncer=true)
#
#  Format: postgresql://postgres.<ref>:PASSWORD@aws-...pooler.supabase.com:6543/postgres?pgbouncer=true
# -----------------------------------------------------------------------------
DATABASE_URL=

# -----------------------------------------------------------------------------
#  DIRECT_URL  —  session/direct connection (port 5432)
# -----------------------------------------------------------------------------
#  The non-pooled connection, used to run supabase/migrations/*.sql against the
#  DB (e.g. `psql "$DIRECT_URL" -f supabase/migrations/<file>.sql`) and for any
#  Prisma introspection. Not used for normal runtime queries.
#
#  Format: postgresql://postgres.<ref>:PASSWORD@aws-...pooler.supabase.com:5432/postgres
# -----------------------------------------------------------------------------
DIRECT_URL=
