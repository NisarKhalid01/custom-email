// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
//
// The database is Supabase. Prisma is used ONLY as the session-storage client
// (the `Session` model below). Schema/migrations are managed by Supabase — the
// SQL lives in supabase/migrations/. Do NOT run `prisma migrate dev` against
// this DB: it would try to drop `form_submissions` (owned by Supabase, not
// modeled here). Runtime uses the pooled DATABASE_URL (pgbouncer); directUrl is
// the direct connection for any Prisma introspection.
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

// Storefront form submissions live in Supabase table `form_submissions` and are
// accessed via app/lib/supabase.server.js (postgres.js), NOT Prisma. It is
// deliberately not modeled here so Prisma never tries to manage it.
